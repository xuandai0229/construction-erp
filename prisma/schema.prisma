  updatedAt   DateTime @updatedAt
  createdById String?
  project     Project  @relation(fields: [projectId], references: [id])

  @@index([projectId])
  @@index([date])
}

model Quotation {
  id                String           @id @default(uuid())
  purchaseRequestId String?
  vendor            String
  totalAmount       Decimal          @db.Decimal(18, 2)
  leadTimeDays      Int?
  validUntil        DateTime?
  status            String           @default("PENDING")
  notes             String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  purchaseRequest   PurchaseRequest? @relation(fields: [purchaseRequestId], references: [id])

  @@index([purchaseRequestId])
}

model Company {
  id           String         @id @default(uuid())
  name         String
  code         String         @unique
  taxCode      String?
  address      String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  branches     Branch[]
  costs        CostRecord[]
  FiscalPeriod FiscalPeriod[]
  invoices     Invoice[]
  projects     Project[]
  users        User[]
}

model Branch {
  id        String       @id @default(uuid())
  companyId String
  name      String
  code      String       @unique
  address   String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  company   Company      @relation(fields: [companyId], references: [id])
  costs     CostRecord[]
  invoices  Invoice[]
  projects  Project[]
}

model Notification {
  id         String   @id @default(uuid())
  userId     String
  title      String
  message    String
  type       String
  severity   String
  priority   Int      @default(0)
  entityType String?
  entityId   String?
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
