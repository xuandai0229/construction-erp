model WorkflowDefinition {
  id           String   @id @default(uuid())
  companyId    String
  name         String
  entityType   String   // e.g. "PROCUREMENT", "PAYMENT", "CONTRACT", "CHANGE_REQUEST", "PROJECT_PROGRESS"
  isActive     Boolean  @default(true)
  version      Int      @default(1)
  definition   Json     // Full configuration of states, transitions, rules, SLA timeouts, escalations, approver roles
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([companyId, entityType])
}

model SagaState {
  id            String   @id @default(uuid())
  companyId     String
  sagaType      String
  status        String   // PENDING, PROCESSING, COMPLETED, FAILED, ROLLED_BACK
  steps         Json     // Array of saga steps with compensation status
  context       Json     // Initial transaction payload
  currentStep   Int      @default(0)
  correlationId String   @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([companyId, sagaType])
}

model ReadModel {
  id        String   @id // Formatted as "companyId:modelType:entityId"
  companyId String
  type      String   // e.g. "CASHFLOW_SUMMARY", "PROJECT_INSIGHTS", "EXECUTIVE_KPI"
  data      Json
  version   Int      @default(1)
  updatedAt DateTime @updatedAt

  @@index([companyId, type])
}

model OrganizationUnit {
  id        String             @id @default(uuid())
  companyId String
  name      String
  type      String             // "CORPORATION" | "REGION" | "BRANCH" | "DEPARTMENT" | "TEAM"
  parentId  String?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  parent    OrganizationUnit?  @relation("OrgHierarchy", fields: [parentId], references: [id])
  children  OrganizationUnit[] @relation("OrgHierarchy")

  @@index([companyId])
  @@index([parentId])
}

model BankAccount {
  id             String            @id @default(uuid())
  accountNumber  String            @unique
  bankName       String
  currency       String            @default("VND")
  balance        Decimal           @default(0) @db.Decimal(18, 2)
  transactions   BankTransaction[]
  paymentBatches PaymentBatch[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

model BankTransaction {
  id            String          @id @default(uuid())
  bankAccountId String
  date          DateTime        @default(now())
  amount        Decimal         @db.Decimal(18, 2)
  description   String
  reference     String?
  type          TransactionType // DEBIT or CREDIT
  isMatched     Boolean         @default(false)
  bankAccount   BankAccount     @relation(fields: [bankAccountId], references: [id])
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model BankStatement {
  id          String   @id @default(uuid())
  importDate  DateTime @default(now())
  fileName    String
  rawData     Json
  createdAt   DateTime @default(now())
}

model PaymentBatch {
  id             String            @id @default(uuid())
  bankAccountId  String
  name           String
  status         String            @default("DRAFT") // DRAFT, PENDING, APPROVED, COMPLETED
  totalAmount    Decimal           @db.Decimal(18, 2)
  bankAccount    BankAccount       @relation(fields: [bankAccountId], references: [id])
  approvals      TreasuryApproval[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

model TreasuryApproval {
  id             String        @id @default(uuid())
  paymentBatchId String
  userId         String
  status         String        @default("PENDING") // PENDING, APPROVED, REJECTED
  comment        String?
  paymentBatch   PaymentBatch  @relation(fields: [paymentBatchId], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model CashReservation {
  id          String   @id @default(uuid())
  projectId   String
  amount      Decimal  @db.Decimal(18, 2)
  reason      String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ═══════════════════════════════════════════════════════════════
// PHASE 9: CPM SCHEDULING ENGINE
// ═══════════════════════════════════════════════════════════════

model Activity {
  id                String               @id @default(uuid())
  projectId         String
  wbsId             String?
  code              String               // e.g. "A1010", "A2030"
  name              String
  description       String?
  // Planned (Baseline)
  plannedStart      DateTime?
  plannedFinish     DateTime?
  plannedDuration   Int                  @default(0) // calendar days
  // Actual
  actualStart       DateTime?
  actualFinish      DateTime?
  actualDuration    Int?
  // CPM Calculated Fields
  earlyStart        DateTime?
  earlyFinish       DateTime?
  lateStart         DateTime?
  lateFinish        DateTime?
  totalFloat        Int?                 // days
  freeFloat         Int?                 // days
  isCritical        Boolean              @default(false)
  isNearCritical    Boolean              @default(false) // float <= 5 days
  isMilestone       Boolean              @default(false)
  // Completion
  percentComplete   Decimal              @default(0) @db.Decimal(5, 2)
  status            ActivityStatus       @default(NOT_STARTED)
  // Forecasted
  forecastFinish    DateTime?
  // Relations
  predecessors      ActivityDependency[] @relation("Successor")
  successors        ActivityDependency[] @relation("Predecessor")
  delayEvents       DelayEvent[]
  resourceAssignments EquipmentAssignment[]
  crewAssignments   CrewAssignment[]
  // Baseline
  baselineId        String?
  baseline          BaselineSchedule?    @relation(fields: [baselineId], references: [id])
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  deletedAt         DateTime?

  @@unique([projectId, code])
  @@index([projectId, status])
  @@index([isCritical])
  @@index([baselineId])
}

model ActivityDependency {
  id              String         @id @default(uuid())
  predecessorId   String
  successorId     String
  type            DependencyType @default(FS)
  lagDays         Int            @default(0) // positive = lag, negative = lead
  predecessor     Activity       @relation("Predecessor", fields: [predecessorId], references: [id])
  successor       Activity       @relation("Successor", fields: [successorId], references: [id])
  createdAt       DateTime       @default(now())

  @@unique([predecessorId, successorId])
  @@index([predecessorId])
  @@index([successorId])
}

model BaselineSchedule {
  id          String     @id @default(uuid())
  projectId   String
  version     Int        @default(1)
  name        String     // e.g. "Original Baseline", "Rev 1"
  description String?
  snapshotDate DateTime  @default(now())
  isActive    Boolean    @default(true) // only one active per project
  activities  Activity[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([projectId, version])
  @@index([projectId, isActive])
}

model DelayEvent {
  id          String      @id @default(uuid())
  activityId  String
  projectId   String
  category    DelayCategory
  description String
  delayDays   Int         // actual delay days
  startDate   DateTime    // when delay started
  endDate     DateTime?   // when delay ended (null = ongoing)
  isExcusable Boolean     @default(false) // EOT-eligible
  isCompensable Boolean   @default(false) // cost-claimable
  impactCost  Decimal?    @db.Decimal(18, 2)
  status      String      @default("ACTIVE") // ACTIVE, RESOLVED, CLAIMED
  activity    Activity    @relation(fields: [activityId], references: [id])
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([activityId])
  @@index([projectId, category])
}

// ═══════════════════════════════════════════════════════════════
// PHASE 10: RESOURCE PLANNING & PRODUCTIVITY
// ═══════════════════════════════════════════════════════════════

model ResourcePool {
  id          String     @id @default(uuid())
  projectId   String
  name        String     // e.g. "Tổ thép móng", "Tổ ván khuôn"
  type        ResourceType
  capacity    Int        @default(0)
  costPerDay  Decimal    @default(0) @db.Decimal(18, 2)
  crews       LaborCrew[]
  equipment   EquipmentAsset[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([projectId, type])
}

model LaborCrew {
  id              String           @id @default(uuid())
  resourcePoolId  String
  name            String           // e.g. "Tổ thợ hàn 1"
  headCount       Int              @default(0)
  dailyRate       Decimal          @default(0) @db.Decimal(18, 2) // VND/day per crew
  skillLevel      String           @default("STANDARD") // STANDARD, SKILLED, SPECIALIST
  isActive        Boolean          @default(true)
  resourcePool    ResourcePool     @relation(fields: [resourcePoolId], references: [id])
  assignments     CrewAssignment[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([resourcePoolId])
}

model CrewAssignment {
  id          String    @id @default(uuid())
  crewId      String
  activityId  String
  startDate   DateTime
  endDate     DateTime?
  hoursPerDay Decimal   @default(8) @db.Decimal(4, 1)
  crew        LaborCrew @relation(fields: [crewId], references: [id])
  activity    Activity  @relation(fields: [activityId], references: [id])
  createdAt   DateTime  @default(now())

  @@index([crewId])
  @@index([activityId])
}

model EquipmentAsset {
  id              String              @id @default(uuid())
  resourcePoolId  String?
  code            String              @unique
  name            String              // e.g. "Cẩu tháp TC7035"
  type            String              // CRANE, EXCAVATOR, LOADER, PUMP, etc.
  dailyRate       Decimal             @default(0) @db.Decimal(18, 2)
  status          EquipmentStatus     @default(AVAILABLE)
  fuelCostPerDay  Decimal             @default(0) @db.Decimal(18, 2)
  lastMaintenance DateTime?
  nextMaintenance DateTime?
  totalDowntimeDays Int               @default(0)
  resourcePool    ResourcePool?       @relation(fields: [resourcePoolId], references: [id])
  assignments     EquipmentAssignment[]
  breakdowns      EquipmentBreakdown[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([status])
  @@index([resourcePoolId])
}

model EquipmentAssignment {
  id           String         @id @default(uuid())
  equipmentId  String
  activityId   String
  startDate    DateTime
  endDate      DateTime?
  hoursPerDay  Decimal        @default(8) @db.Decimal(4, 1)
  utilization  Decimal        @default(0) @db.Decimal(5, 2) // %
  equipment    EquipmentAsset @relation(fields: [equipmentId], references: [id])
  activity     Activity       @relation(fields: [activityId], references: [id])
  createdAt    DateTime       @default(now())

  @@index([equipmentId])
  @@index([activityId])
}

model EquipmentBreakdown {
  id           String         @id @default(uuid())
  equipmentId  String
  startDate    DateTime
  endDate      DateTime?
  cause        String
  repairCost   Decimal?       @db.Decimal(18, 2)
  downtimeDays Int            @default(0)
  equipment    EquipmentAsset @relation(fields: [equipmentId], references: [id])
  createdAt    DateTime       @default(now())

  @@index([equipmentId])
}

// ═══════════════════════════════════════════════════════════════
// PHASE 11: CLAIMS, VARIATIONS & CHANGE ORDERS
// ═══════════════════════════════════════════════════════════════

model ChangeRequest {
  id              String         @id @default(uuid())
  projectId       String
  title           String
  description     String?
  type            ChangeType     @default(SCOPE_CHANGE)
  status          ApprovalStatus @default(DRAFT)
  // Financial Impact
  costImpact      Decimal        @default(0) @db.Decimal(18, 2)
  // Schedule Impact
  scheduleImpact  Int            @default(0) // days
  // Linkage
  variationOrderId String?
  requestedById   String?
  approvedById    String?
  approvedDate    DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?
  claims          ClaimRecord[]

  @@index([projectId, status])
  @@index([type])
}

model ClaimRecord {
  id              String         @id @default(uuid())
  projectId       String
  changeRequestId String?
  type            ClaimType
  title           String
  description     String?
  claimedAmount   Decimal        @db.Decimal(18, 2)
  approvedAmount  Decimal?       @db.Decimal(18, 2)
  claimedDays     Int            @default(0) // EOT days claimed
  approvedDays    Int?           // EOT days approved
  status          ApprovalStatus @default(DRAFT)
  evidence        String?        // document references
  submittedDate   DateTime?
  resolvedDate    DateTime?
  changeRequest   ChangeRequest? @relation(fields: [changeRequestId], references: [id])
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?

  @@index([projectId, status])
  @@index([type])
  @@index([changeRequestId])
}

// ═══════════════════════════════════════════════════════════════
// PHASE 12: COMMITMENT ACCOUNTING & FUTURE OBLIGATIONS
// ═══════════════════════════════════════════════════════════════

model Commitment {
  id              String           @id @default(uuid())
  projectId       String
  type            CommitmentType
  reference       String?          // PO number, Subcontract number, etc.
  sourceId        String?          // PO ID, Subcontract ID
  description     String
  originalAmount  Decimal          @db.Decimal(18, 2)
  invoicedAmount  Decimal          @default(0) @db.Decimal(18, 2)
  remainingAmount Decimal          @db.Decimal(18, 2)
  dueDate         DateTime?
  status          CommitmentStatus @default(OPEN)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([projectId, type])
  @@index([status])
}

