  DESIGN_CHANGE
  CLIENT_INSTRUCTION
  SITE_CONDITION
  REGULATORY
  VALUE_ENGINEERING
}

enum ClaimType {
  EXTENSION_OF_TIME
  DELAY_COST
  DISRUPTION
  COST_ESCALATION
  VARIATION
  ACCELERATION
}

enum CommitmentType {
  PURCHASE_ORDER
  SUBCONTRACT
  PAYROLL
  EQUIPMENT_LEASE
  RETENTION
}

enum CommitmentStatus {
  OPEN
  PARTIALLY_INVOICED
  FULLY_INVOICED
  CLOSED
  CANCELLED
}


