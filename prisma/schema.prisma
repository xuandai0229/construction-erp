  accountingPeriod   AccountingPeriod @relation(fields: [accountingPeriodId], references: [id])
  project            Project          @relation(fields: [projectId], references: [id])

  @@unique([accountingPeriodId, projectId, accountCode])
  @@index([accountingPeriodId])
  @@index([projectId])
}

model ProfitLossSnapshot {
  id                 String           @id @default(uuid())
  accountingPeriodId String
  projectId          String
  totalRevenue       Decimal          @default(0) @db.Decimal(18, 2)
  totalCost          Decimal          @default(0) @db.Decimal(18, 2)
  grossProfit        Decimal          @default(0) @db.Decimal(18, 2)
  grossMargin        Decimal          @default(0) @db.Decimal(18, 4)
  netProfit          Decimal          @default(0) @db.Decimal(18, 2)
  generatedAt        DateTime         @default(now())
  generatedById      String?
  accountingPeriod   AccountingPeriod @relation(fields: [accountingPeriodId], references: [id])
  project            Project          @relation(fields: [projectId], references: [id])

  @@unique([accountingPeriodId, projectId])
  @@index([accountingPeriodId])
  @@index([projectId])
}

model Supplier {
  id                String              @id @default(uuid())
  code              String              @unique
  name              String
  description       String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  deletedAt         DateTime?
  advanceRequests   AdvanceRequest[]
  contracts         Contract[]
  InventoryDocument InventoryDocument[]
  projects          ProjectSupplier[]
}

model ProjectSupplier {
  id         String   @id @default(uuid())
  projectId  String
  supplierId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  project    Project  @relation(fields: [projectId], references: [id])
  supplier   Supplier @relation(fields: [supplierId], references: [id])

  @@unique([projectId, supplierId])
}

model Acceptance {
  id               String    @id @default(uuid())
  contractId       String
  acceptanceNumber String
  amount           Decimal   @db.Decimal(18, 2)
  date             DateTime  @default(now())
  note             String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?
  contract         Contract  @relation(fields: [contractId], references: [id])

  @@unique([contractId, acceptanceNumber])
}

model PaymentPlan {
  id            String   @id @default(uuid())
  contractId    String
  dueDate       DateTime
  amount        Decimal  @db.Decimal(18, 2)
  paymentMethod String?
  status        String   @default("PENDING")
  note          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  contract      Contract @relation(fields: [contractId], references: [id])
}

model DocumentChecklist {
  id         String   @id @default(uuid())
  contractId String
  name       String
  status     String   @default("MISSING")
  note       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  contract   Contract @relation(fields: [contractId], references: [id])
}

model AdvanceRequest {
  id                     String               @id @default(uuid())
  companyId              String?
  projectId              String?
  contractId             String?
  wbsItemId              String?
  supplierId             String?
  employeeId             String?
  recipientType          AdvanceRecipientType
  advanceNo              String?
  amount                 Decimal              @db.Decimal(18, 2)
  paidAmount             Decimal              @default(0) @db.Decimal(18, 2)
  settledAmount          Decimal              @default(0) @db.Decimal(18, 2)
  remainingAmount        Decimal              @db.Decimal(18, 2)
  purpose                String?
  status                 AdvanceStatus        @default(DRAFT)
  requestedBy            String?
  approvedBy             String?
  approvedAt             DateTime?
  paidAt                 DateTime?
  expectedSettlementDate DateTime?
  postedJournalEntryId   String?
  reversalJournalEntryId String?
  exceptionReason        String?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  deletedAt              DateTime?
  version                Int                  @default(1)
  approver               User?                @relation("AdvanceApprover", fields: [approvedBy], references: [id])
  company                Company?             @relation(fields: [companyId], references: [id])
  contract               Contract?            @relation(fields: [contractId], references: [id])
  employee               User?                @relation("AdvanceEmployee", fields: [employeeId], references: [id])
  project                Project?             @relation(fields: [projectId], references: [id])
  requester              User?                @relation("AdvanceRequester", fields: [requestedBy], references: [id])
  supplier               Supplier?            @relation(fields: [supplierId], references: [id])
  settlements            AdvanceSettlement[]

  @@index([companyId])
  @@index([projectId])
  @@index([contractId])
  @@index([supplierId])
  @@index([recipientType])
  @@index([status])
  @@index([expectedSettlementDate])
}

model AdvanceSettlement {
  id                     String           @id @default(uuid())
  companyId              String?
  advanceRequestId       String
  invoiceId              String?
  costRecordId           String?
  paymentId              String?
  contractId             String?
  amount                 Decimal          @db.Decimal(18, 2)
  status                 SettlementStatus @default(DRAFT)
  settlementDate         DateTime         @default(now())
  postedJournalEntryId   String?
  reversalJournalEntryId String?
  reason                 String?
  createdBy              String?
  approvedBy             String?
  approvedAt             DateTime?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  deletedAt              DateTime?
  version                Int              @default(1)
  advanceRequest         AdvanceRequest   @relation(fields: [advanceRequestId], references: [id])
  approver               User?            @relation("SettlementApprover", fields: [approvedBy], references: [id])
  company                Company?         @relation(fields: [companyId], references: [id])
  creator                User?            @relation("SettlementCreator", fields: [createdBy], references: [id])
  invoice                Invoice?         @relation(fields: [invoiceId], references: [id])

  @@index([companyId])
  @@index([advanceRequestId])
  @@index([invoiceId])
  @@index([status])
}

model CashBankDocument {
  id                   String                 @id @default(uuid())
  companyId            String?
  projectId            String?
  contractId           String?
  documentType         CashBankDocumentType
  documentNo           String
  documentDate         DateTime               @default(now())
  accountingDate       DateTime               @default(now())
  amount               Decimal                @db.Decimal(18, 2)
  currency             String                 @default("VND")
  description          String
  partnerName          String?
  paymentMethod        String
  debitAccountId       String
  creditAccountId      String
  status               CashBankDocumentStatus @default(DRAFT)
  createdBy            String
  approvedBy           String?
  approvedAt           DateTime?
  postedJournalEntryId String?
  isReversed           Boolean                @default(false)
  reversalRef          String?
  deletedAt            DateTime?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  company              Company?               @relation(fields: [companyId], references: [id])
  contract             Contract?              @relation(fields: [contractId], references: [id])
  creditAccount        LedgerAccount          @relation("CreditAccount", fields: [creditAccountId], references: [id])
  debitAccount         LedgerAccount          @relation("DebitAccount", fields: [debitAccountId], references: [id])
  project              Project?               @relation(fields: [projectId], references: [id])

  @@unique([companyId, documentType, documentNo, deletedAt])
  @@index([companyId])
  @@index([projectId])
  @@index([documentType])
  @@index([status])
}

model TaxInvoice {
  id                   String              @id @default(uuid())
  companyId            String?
  projectId            String?
  contractId           String?
  wbsId                String?
  invoiceType          TaxInvoiceType
  invoiceNumber        String
  invoiceSeries        String
  invoiceTemplate      String              @default("1C26TBB")
  invoiceDate          DateTime            @default(now())
  partnerName          String
  partnerTaxCode       String
  partnerAddress       String?
  netAmount            Decimal             @db.Decimal(18, 2)
  vatRate              Decimal             @default(10) @db.Decimal(5, 2)
  vatAmount            Decimal             @db.Decimal(18, 2)
  grossAmount          Decimal             @db.Decimal(18, 2)
  status               TaxInvoiceStatus    @default(DRAFT)
  description          String?
  sourceType           String?
  sourceId             String?
  postedJournalEntryId String?
  deletedAt            DateTime?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  inventoryDocument    InventoryDocument[]
  company              Company?            @relation(fields: [companyId], references: [id])
  contract             Contract?           @relation(fields: [contractId], references: [id])
  project              Project?            @relation(fields: [projectId], references: [id])
  wbs                  WBSItem?            @relation(fields: [wbsId], references: [id])

  @@unique([companyId, invoiceType, invoiceNumber, invoiceSeries, deletedAt])
  @@index([companyId])
  @@index([projectId])
  @@index([invoiceType])
  @@index([status])
  @@index([invoiceDate])
}

model MaterialItem {
  id                 String                  @id @default(uuid())
  companyId          String
  code               String
  name               String
  unit               String
  group              String?
  defaultWarehouseId String?
  inventoryAccount   String                  @default("152")
  expenseAccount     String                  @default("621")
  vatRate            Decimal                 @default(10) @db.Decimal(5, 2)
  isActive           Boolean                 @default(true)
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  deletedAt          DateTime?
  balances           InventoryBalance[]
  lines              InventoryDocumentLine[]
  movements          InventoryMovement[]
  company            Company                 @relation(fields: [companyId], references: [id])

  @@unique([companyId, code, deletedAt])
  @@index([companyId])
  @@index([code])
}

model Warehouse {
  id          String                  @id @default(uuid())
  companyId   String
  projectId   String?
  code        String
  name        String
  address     String?
  managerName String?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  deletedAt   DateTime?
  balances    InventoryBalance[]
  sourceLines InventoryDocumentLine[] @relation("SourceWarehouse")
  targetLines InventoryDocumentLine[] @relation("TargetWarehouse")
  movements   InventoryMovement[]
  company     Company                 @relation(fields: [companyId], references: [id])
  project     Project?                @relation(fields: [projectId], references: [id])

  @@unique([companyId, code, deletedAt])
  @@index([companyId])
  @@index([projectId])
}

model InventoryDocument {
  id                     String                  @id @default(uuid())
  companyId              String
  projectId              String?
  wbsId                  String?
  documentType           InventoryDocumentType
  documentNo             String
  documentDate           DateTime                @default(now())
  accountingDate         DateTime                @default(now())
  status                 InventoryDocumentStatus @default(DRAFT)
  supplierId             String?
  contractId             String?
  vatInvoiceId           String?
  sourceWarehouseId      String?
  targetWarehouseId      String?
  partnerName            String?
  description            String?
  netAmount              Decimal                 @default(0) @db.Decimal(18, 2)
  vatAmount              Decimal                 @default(0) @db.Decimal(18, 2)
  grossAmount            Decimal                 @default(0) @db.Decimal(18, 2)
  createdBy              String
  approvedBy             String?
  approvedAt             DateTime?
  postedJournalEntryId   String?
  reversalJournalEntryId String?
  rejectReason           String?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  deletedAt              DateTime?
  company                Company                 @relation(fields: [companyId], references: [id])
  contract               Contract?               @relation(fields: [contractId], references: [id])
  project                Project?                @relation(fields: [projectId], references: [id])
  supplier               Supplier?               @relation(fields: [supplierId], references: [id])
  taxInvoice             TaxInvoice?             @relation(fields: [vatInvoiceId], references: [id])
  wbs                    WBSItem?                @relation(fields: [wbsId], references: [id])
  lines                  InventoryDocumentLine[]
  movements              InventoryMovement[]

  @@unique([companyId, documentType, documentNo, deletedAt])
  @@index([companyId])
  @@index([projectId])
  @@index([documentType])
  @@index([status])
}

model InventoryDocumentLine {
  id                  String              @id @default(uuid())
  inventoryDocumentId String
  materialItemId      String
  quantity            Decimal             @db.Decimal(18, 4)
  unitCost            Decimal             @db.Decimal(18, 2)
  amount              Decimal             @db.Decimal(18, 2)
  vatRate             Decimal?            @db.Decimal(5, 2)
  vatAmount           Decimal?            @db.Decimal(18, 2)
  grossAmount         Decimal?            @db.Decimal(18, 2)
  debitAccount        String?
  creditAccount       String?
  sourceWarehouseId   String?
  targetWarehouseId   String?
  projectId           String?
  wbsId               String?
  document            InventoryDocument   @relation(fields: [inventoryDocumentId], references: [id])
  material            MaterialItem        @relation(fields: [materialItemId], references: [id])
  sourceWarehouse     Warehouse?          @relation("SourceWarehouse", fields: [sourceWarehouseId], references: [id])
  targetWarehouse     Warehouse?          @relation("TargetWarehouse", fields: [targetWarehouseId], references: [id])
  movements           InventoryMovement[]

  @@index([inventoryDocumentId])
  @@index([materialItemId])
}

model InventoryMovement {
  id                      String                @id @default(uuid())
  companyId               String
  inventoryDocumentId     String
  inventoryDocumentLineId String
  materialItemId          String
  warehouseId             String
  projectId               String?
  wbsId                   String?
  movementDate            DateTime
  documentType            InventoryDocumentType
  documentNo              String
  quantity                Decimal               @db.Decimal(18, 4)
  unitCost                Decimal               @db.Decimal(18, 2)
  amount                  Decimal               @db.Decimal(18, 2)
  createdAt               DateTime              @default(now())
  company                 Company               @relation(fields: [companyId], references: [id])
  document                InventoryDocument     @relation(fields: [inventoryDocumentId], references: [id])
  line                    InventoryDocumentLine @relation(fields: [inventoryDocumentLineId], references: [id])
  material                MaterialItem          @relation(fields: [materialItemId], references: [id])
  warehouse               Warehouse             @relation(fields: [warehouseId], references: [id])

  @@index([companyId])
  @@index([warehouseId])
  @@index([materialItemId])
  @@index([projectId])
}

model InventoryBalance {
  id             String       @id @default(uuid())
  companyId      String
  warehouseId    String
  materialItemId String
  projectId      String?
  wbsId          String?
  quantity       Decimal      @default(0) @db.Decimal(18, 4)
  totalCost      Decimal      @default(0) @db.Decimal(18, 2)
  avgCost        Decimal      @default(0) @db.Decimal(18, 2)
  updatedAt      DateTime     @updatedAt
  company        Company      @relation(fields: [companyId], references: [id])
  material       MaterialItem @relation(fields: [materialItemId], references: [id])
  warehouse      Warehouse    @relation(fields: [warehouseId], references: [id])

  @@unique([warehouseId, materialItemId, projectId, wbsId])
  @@index([companyId])
  @@index([warehouseId])
  @@index([materialItemId])
}

