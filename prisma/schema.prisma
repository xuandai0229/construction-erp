  @@index([userId])
}

model UserMaturity {
  id             String   @id
  userId         String   @unique
  accuracy       Decimal  @default(100) @db.Decimal(5, 2)
  maturityLevel  String   @default("BEGINNER")
  lastAssessedAt DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime
  User           User     @relation(fields: [userId], references: [id])
}

model VariationOrder {
  id          String         @id @default(uuid())
  projectId   String
  boqItemId   String?
  wbsId       String?
  title       String
  description String?
  amount      Decimal        @db.Decimal(18, 2)
  status      ApprovalStatus @default(DRAFT)
  type        String         @default("ADDITION")
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  createdById String?
  project     Project        @relation(fields: [projectId], references: [id])
  wbs         WBSItem?       @relation(fields: [wbsId], references: [id])

  @@index([projectId])
  @@index([status])
}

model SiteLog {
  id          String   @id @default(uuid())
  projectId   String
  date        DateTime @default(now())
  weather     String?
  temperature Float?
  manpower    Int      @default(0)
  equipment   String?
  progress    String?
  notes       String?
