generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma-client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum UserRole {
  ADMIN
  MANAGER
  ACCOUNTANT
  VIEWER
}

enum ProjectStatus {
  PLANNED
  IN_PROGRESS
  ACTIVE
  COMPLETED
  CLOSED
  CANCELLED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum CostType {
  material
  labor
  machine
  subcontract
  overhead
  other
}

enum PaymentStatus {
  paid
  unpaid
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIAL
  PAID
  OVERDUE
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE
}

enum TransactionType {
  DEBIT
  CREDIT
}

// NEW ENUMS
enum ProcurementStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  ORDERED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

enum ContractStatus {
  DRAFT
  ACTIVE
  AMENDED
  COMPLETED
  TERMINATED
}

// ─────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  role      UserRole @default(VIEWER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  projectsOwned    Project[]  @relation("ProjectOwner")
  tasksAssigned    Task[]
  costsCreated     CostRecord[]   @relation("CostCreatedBy")
  budgetsCreated   BudgetRecord[] @relation("BudgetCreatedBy")
  revenuesCreated  Revenue[]      @relation("RevenueCreatedBy")
  invoicesCreated  Invoice[]      @relation("InvoiceCreatedBy")
  auditLogs        AuditLog[]

  purchaseRequestsCreated PurchaseRequest[] @relation("PRCreatedBy")
  purchaseOrdersCreated   PurchaseOrder[]   @relation("POCreatedBy")
  contractsCreated        Contract[]        @relation("ContractCreatedBy")

  @@index([createdAt])
  @@index([role])
}

// ─────────────────────────────────────────────
// CATEGORY
// ─────────────────────────────────────────────

model Category {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  tasks Task[]

  @@index([createdAt])
}

// ─────────────────────────────────────────────
// PROJECT
// ─────────────────────────────────────────────

model Project {
  id            String        @id @default(uuid())
  name          String
  description   String?
  status        ProjectStatus @default(PLANNED)
  ownerId       String?

  // Financial fields (Accounting Grade)
  contractValue Decimal       @default(0) @db.Decimal(18, 2)
  totalBudget   Decimal       @default(0) @db.Decimal(18, 2)

  // Schedule
  startDate     DateTime?
  endDate       DateTime?

  // Audit
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?

  owner     User?     @relation("ProjectOwner", fields: [ownerId], references: [id])
  tasks     Task[]
  wbsItems  WBSItem[]
  journalEntries JournalEntry[]
  contracts      Contract[]
  purchaseOrders PurchaseOrder[]

  @@index([status])
  @@index([createdAt])
  @@index([ownerId])
}

// ─────────────────────────────────────────────
// TASK
// ─────────────────────────────────────────────

model Task {
  id          String     @id @default(uuid())
  title       String
  description String?
  status      TaskStatus @default(TODO)
  projectId   String
  categoryId  String?
  assigneeId  String?
  dueDate     DateTime?
  priority    Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?

  project  Project   @relation(fields: [projectId], references: [id])
  category Category? @relation(fields: [categoryId], references: [id])
  assignee User?     @relation(fields: [assigneeId], references: [id])

  @@index([projectId])
  @@index([status])
  @@index([assigneeId])
  @@index([categoryId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────
// WBS
// ─────────────────────────────────────────────

model WBSItem {
  id        String  @id @default(uuid())
  projectId String
  name      String
  code      String?
  parentId  String?
  level     Int     @default(0)
  sortOrder Int     @default(0)

  budgetAmount Decimal @default(0) @db.Decimal(18, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project  Project   @relation(fields: [projectId], references: [id])
  parent   WBSItem?  @relation("WBSChildren", fields: [parentId], references: [id])
  children WBSItem[] @relation("WBSChildren")

  costs    CostRecord[]
  budgets  BudgetRecord[]
  revenues Revenue[]
  invoices Invoice[]
  purchaseOrderItems PurchaseOrderItem[]

  @@index([projectId])
  @@index([parentId])
}

// ─────────────────────────────────────────────
// COST RECORD
// ─────────────────────────────────────────────

model CostRecord {
  id           String        @id @default(uuid())
  projectId    String
  wbsId        String
  costType     CostType      @default(material)
  amount       Decimal       @db.Decimal(18, 2)
  quantity     Decimal       @default(1) @db.Decimal(18, 2)
  unitPrice    Decimal       @default(0) @db.Decimal(18, 2)
  supplier     String?
  note         String?
  date         DateTime      @default(now())
  status       PaymentStatus @default(unpaid)
  requestId    String?       @unique // Idempotency

  // Link to procurement
  purchaseOrderId String?

  createdById  String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  wbs       WBSItem       @relation(fields: [wbsId], references: [id])
  createdBy User?         @relation("CostCreatedBy", fields: [createdById], references: [id])
  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])

  @@index([projectId])
  @@index([wbsId])
  @@index([date])
}

// ─────────────────────────────────────────────
// BUDGET RECORD
// ─────────────────────────────────────────────

model BudgetRecord {
  id              String   @id @default(uuid())
  projectId       String
  wbsId           String
  costType        CostType @default(material)
  estimatedAmount Decimal  @db.Decimal(18, 2)

  createdById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  wbs       WBSItem @relation(fields: [wbsId], references: [id])
  createdBy User?   @relation("BudgetCreatedBy", fields: [createdById], references: [id])

  @@index([projectId])
  @@index([wbsId])
}

// ─────────────────────────────────────────────
// REVENUE
// ─────────────────────────────────────────────

model Revenue {
  id          String        @id @default(uuid())
  projectId   String
  wbsId       String
  invoiceId   String?
  amount      Decimal       @db.Decimal(18, 2)
  date        DateTime      @default(now())
  status      PaymentStatus @default(unpaid)
  description String?

  createdById String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  wbs       WBSItem  @relation(fields: [wbsId], references: [id])
  invoice   Invoice? @relation(fields: [invoiceId], references: [id])
  createdBy User?    @relation("RevenueCreatedBy", fields: [createdById], references: [id])

  @@index([projectId])
  @@index([wbsId])
}

// ─────────────────────────────────────────────
// INVOICE
// ─────────────────────────────────────────────

model Invoice {
  id              String        @id @default(uuid())
  projectId       String
  wbsId           String
  invoiceNumber   String?
  amount          Decimal       @db.Decimal(18, 2)
  issuedDate      DateTime      @default(now())
  dueDate         DateTime?
  paidAmount      Decimal       @default(0) @db.Decimal(18, 2)
  remainingAmount Decimal       @db.Decimal(18, 2)
  status          InvoiceStatus @default(DRAFT)
  note            String?
  requestId       String?       @unique // Idempotency

  createdById     String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  wbs       WBSItem   @relation(fields: [wbsId], references: [id])
  payments  Payment[]
  revenues  Revenue[]
  createdBy User?     @relation("InvoiceCreatedBy", fields: [createdById], references: [id])

  // Link to contract
  contractId String?
  contract   Contract? @relation(fields: [contractId], references: [id])

  @@index([projectId])
  @@index([wbsId])
}

// ─────────────────────────────────────────────
// PAYMENT
// ─────────────────────────────────────────────

model Payment {
  id          String   @id @default(uuid())
  invoiceId   String
  projectId   String
  amount      Decimal  @db.Decimal(18, 2)
  date        DateTime @default(now())
  description String?
  requestId   String?  @unique // Idempotency
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
  @@index([projectId])
}

// ─────────────────────────────────────────────
// ACCOUNTING (LEDGER)
// ─────────────────────────────────────────────

model LedgerAccount {
  id          String      @id @default(uuid())
  code        String      @unique // e.g. 1010 (Cash), 4010 (Revenue)
  name        String
  type        AccountType
  description String?
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  lines       TransactionLine[]

  @@index([code])
  @@index([type])
}

model JournalEntry {
  id          String   @id @default(uuid())
  projectId   String?
  date        DateTime @default(now())
  description String
  reference   String?  // e.g. Invoice #123
  // Source tracking: which entity triggered this entry
  sourceType  String?  // e.g. "PAYMENT", "COST", "INVOICE"
  sourceId    String?  // FK to the source record
  isPosted    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project     Project? @relation(fields: [projectId], references: [id])
  lines       TransactionLine[]

  @@index([projectId])
  @@index([date])
  @@index([sourceType, sourceId])
}

model TransactionLine {
  id              String          @id @default(uuid())
  journalEntryId  String
  accountId       String
  amount          Decimal         @db.Decimal(18, 2)
  type            TransactionType // DEBIT or CREDIT
  description     String?

  journalEntry    JournalEntry    @relation(fields: [journalEntryId], references: [id])
  account         LedgerAccount   @relation(fields: [accountId], references: [id])

  @@index([journalEntryId])
  @@index([accountId])
}

// ─────────────────────────────────────────────
// PROCUREMENT
// ─────────────────────────────────────────────

model PurchaseRequest {
  id          String            @id @default(uuid())
  projectId   String
  wbsId       String?
  title       String
  description String?
  requestedBy String?
  status      ProcurementStatus @default(DRAFT)
  totalAmount Decimal           @default(0) @db.Decimal(18, 2)
  requestDate DateTime          @default(now())
  neededBy    DateTime?
  createdById String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  createdBy      User?           @relation("PRCreatedBy", fields: [createdById], references: [id])
  purchaseOrders PurchaseOrder[]

  @@index([projectId])
  @@index([status])
}

model PurchaseOrder {
  id                String            @id @default(uuid())
  projectId         String
  purchaseRequestId String?
  poNumber          String?           @unique
  vendor            String
  description       String?
  status            ProcurementStatus @default(DRAFT)
  totalAmount       Decimal           @db.Decimal(18, 2)
  orderedDate       DateTime          @default(now())
  expectedDelivery  DateTime?
  createdById       String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  project         Project          @relation(fields: [projectId], references: [id])
  purchaseRequest PurchaseRequest? @relation(fields: [purchaseRequestId], references: [id])
  createdBy       User?            @relation("POCreatedBy", fields: [createdById], references: [id])
  items           PurchaseOrderItem[]
  goodsReceipts   GoodsReceipt[]
  costRecords     CostRecord[]

  @@index([projectId])
  @@index([status])
}

model PurchaseOrderItem {
  id              String   @id @default(uuid())
  purchaseOrderId String
  wbsId           String?
  description     String
  quantity        Decimal  @db.Decimal(18, 4)
  unitPrice       Decimal  @db.Decimal(18, 2)
  amount          Decimal  @db.Decimal(18, 2)
  costType        CostType @default(material)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  wbs           WBSItem?      @relation(fields: [wbsId], references: [id])

  @@index([purchaseOrderId])
}

model GoodsReceipt {
  id              String   @id @default(uuid())
  purchaseOrderId String
  projectId       String
  receivedDate    DateTime @default(now())
  notes           String?
  receivedById    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])

  @@index([purchaseOrderId])
  @@index([projectId])
}

// ─────────────────────────────────────────────
// CONTRACT & VARIATION
// ─────────────────────────────────────────────

model Contract {
  id                String         @id @default(uuid())
  projectId         String
  contractNumber    String?        @unique
  title             String
  description       String?
  contractorName    String?
  originalValue     Decimal        @db.Decimal(18, 2)
  currentValue      Decimal        @db.Decimal(18, 2)
  status            ContractStatus @default(DRAFT)
  signedDate        DateTime?
  startDate         DateTime?
  endDate           DateTime?
  createdById       String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  project    Project         @relation(fields: [projectId], references: [id])
  createdBy  User?           @relation("ContractCreatedBy", fields: [createdById], references: [id])
  changes    ContractChange[]
  invoices   Invoice[]

  @@index([projectId])
  @@index([status])
}

model ContractChange {
  id           String   @id @default(uuid())
  contractId   String
  voNumber     String?  // Variation Order number
  title        String
  description  String?
  changeAmount Decimal  @db.Decimal(18, 2) // Positive = increase, Negative = decrease
  approvedDate DateTime?
  status       String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  contract Contract @relation(fields: [contractId], references: [id])

  @@index([contractId])
}

// ─────────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(uuid())
  userId      String?
  action      String   // e.g. CREATE, UPDATE, DELETE
  entity      String   // e.g. CostRecord
  entityId    String
  oldData     Json?
  newData     Json?
  timestamp   DateTime @default(now())
  ipAddress   String?
  userAgent   String?

  user        User?    @relation(fields: [userId], references: [id])

  @@index([entity, entityId])
  @@index([timestamp])
  @@index([userId])
}