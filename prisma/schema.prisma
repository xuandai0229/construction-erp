generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma-client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                                                 String              @id @default(uuid())
  email                                              String              @unique
  name                                               String?
  createdAt                                          DateTime            @default(now())
  updatedAt                                          DateTime            @updatedAt
  deletedAt                                          DateTime?
  companyId                                          String?
  role                                               UserRole            @default(VIEWER)
  accountingPeriodsClosed                            AccountingPeriod[]  @relation("AccountingPeriodClosedBy")
  ActivityFeed                                       ActivityFeed[]
  advanceApprover                                    AdvanceRequest[]    @relation("AdvanceApprover")
  advanceEmployee                                    AdvanceRequest[]    @relation("AdvanceEmployee")
  advanceRequester                                   AdvanceRequest[]    @relation("AdvanceRequester")
  settlementApprover                                 AdvanceSettlement[] @relation("SettlementApprover")
  settlementCreator                                  AdvanceSettlement[] @relation("SettlementCreator")
  ApprovalRequest                                    ApprovalRequest[]
  ApprovalStep                                       ApprovalStep[]
  auditLogs                                          AuditLog[]
  budgetsCreated                                     BudgetRecord[]      @relation("BudgetCreatedBy")
  Comment                                            Comment[]
  contractsCreated                                   Contract[]          @relation("ContractCreatedBy")
  costsCreated                                       CostRecord[]        @relation("CostCreatedBy")
  costsDeleted                                       CostRecord[]        @relation("CostDeletedBy")
  DelegationWindow_DelegationWindow_delegateIdToUser DelegationWindow[]  @relation("DelegationWindow_delegateIdToUser")
  DelegationWindow_DelegationWindow_ownerIdToUser    DelegationWindow[]  @relation("DelegationWindow_ownerIdToUser")
  Document                                           Document[]
  FiscalPeriod                                       FiscalPeriod[]
  fiscalYearsClosed                                  FiscalYear[]        @relation("FiscalYearClosedBy")
  invoicesCreated                                    Invoice[]           @relation("InvoiceCreatedBy")
  invoicesDeleted                                    Invoice[]           @relation("InvoiceDeletedBy")
  notifications                                      Notification[]
  paymentsDeleted                                    Payment[]           @relation("PaymentDeletedBy")
  ProgressEntry                                      ProgressEntry[]
  projectsDeleted                                    Project[]           @relation("ProjectDeletedBy")
  projectsOwned                                      Project[]           @relation("ProjectOwner")
  purchaseOrdersCreated                              PurchaseOrder[]     @relation("POCreatedBy")
  purchaseRequestsCreated                            PurchaseRequest[]   @relation("PRCreatedBy")
  revenuesCreated                                    Revenue[]           @relation("RevenueCreatedBy")
  tasksAssigned                                      Task[]
  TrainingRecord                                     TrainingRecord[]
  company                                            Company?            @relation(fields: [companyId], references: [id])
  UserMaturity                                       UserMaturity?
  wbsDeleted                                         WBSItem[]           @relation("WBSDeletedBy")

  @@index([createdAt])
  @@index([companyId])
}

model Category {
  id        String    @id @default(uuid())
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  tasks     Task[]

  @@index([createdAt])
}

model Project {
  id                    String                 @id @default(uuid())
  name                  String
  createdAt             DateTime               @default(now())
  deletedAt             DateTime?
  description           String?
  ownerId               String?
  status                ProjectStatus          @default(PLANNED)
  updatedAt             DateTime               @updatedAt
  branchId              String?
  companyId             String?
  contractValue         Decimal                @default(0) @db.Decimal(18, 2)
  deletedById           String?
  endDate               DateTime?
  investor              String?
  projectType           String?
  startDate             DateTime?
  totalBudget           Decimal                @default(0) @db.Decimal(18, 2)
  version               Int                    @default(1)
  ActivityFeed          ActivityFeed[]
  advanceRequests       AdvanceRequest[]
  ApprovalRequest       ApprovalRequest[]
  BOQItem               BOQItem[]
  balanceSheetSnapshots BalanceSheetSnapshot[]
  BudgetVersion         BudgetVersion[]
  CashBankDocument      CashBankDocument[]
  contracts             Contract[]
  Document              Document[]
  InventoryDocument     InventoryDocument[]
  InventoryTransaction  InventoryTransaction[]
  journalEntries        JournalEntry[]
  profitLossSnapshots   ProfitLossSnapshot[]
  branch                Branch?                @relation(fields: [branchId], references: [id])
  company               Company?               @relation(fields: [companyId], references: [id])
  deletedBy             User?                  @relation("ProjectDeletedBy", fields: [deletedById], references: [id])
  owner                 User?                  @relation("ProjectOwner", fields: [ownerId], references: [id])
  suppliers             ProjectSupplier[]
  purchaseOrders        PurchaseOrder[]
  SiteConsumption       SiteConsumption[]
  SiteLog               SiteLog[]
  Subcontract           Subcontract[]
  tasks                 Task[]
  TaxInvoice            TaxInvoice[]
  trialBalanceSnapshots TrialBalanceSnapshot[]
  VariationOrder        VariationOrder[]
  VendorPayment         VendorPayment[]
  wbsItems              WBSItem[]
  Warehouse             Warehouse[]

  @@index([status])
  @@index([ownerId])
  @@index([companyId, deletedAt, createdAt])
}

model Task {
  id          String     @id @default(uuid())
  title       String
  description String?
  status      TaskStatus @default(TODO)
  projectId   String
  categoryId  String?
  assigneeId  String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?
  dueDate     DateTime?
  priority    Int        @default(0)
  assignee    User?      @relation(fields: [assigneeId], references: [id])
  category    Category?  @relation(fields: [categoryId], references: [id])
  project     Project    @relation(fields: [projectId], references: [id])

  @@index([status])
  @@index([assigneeId])
  @@index([categoryId])
  @@index([createdAt])
  @@index([projectId, deletedAt])
}

model WBSItem {
  id                 String              @id @default(uuid())
  projectId          String
  name               String
  parentId           String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  budgetAmount       Decimal             @default(0) @db.Decimal(18, 2)
  code               String?
  deletedAt          DateTime?
  deletedById        String?
  level              Int                 @default(0)
  sortOrder          Int                 @default(0)
  BOQItem            BOQItem[]
  budgets            BudgetRecord[]
  costs              CostRecord[]
  InventoryDocument  InventoryDocument[]
  invoices           Invoice[]
  purchaseOrderItems PurchaseOrderItem[]
  revenues           Revenue[]
  SiteConsumption    SiteConsumption[]
  SubcontractItem    SubcontractItem[]
  TaxInvoice         TaxInvoice[]
  VariationOrder     VariationOrder[]
  deletedBy          User?               @relation("WBSDeletedBy", fields: [deletedById], references: [id])
  parent             WBSItem?            @relation("WBSChildren", fields: [parentId], references: [id])
  children           WBSItem[]           @relation("WBSChildren")
  project            Project             @relation(fields: [projectId], references: [id])

  @@index([parentId])
  @@index([projectId, deletedAt])
}

model CostRecord {
  id              String          @id @default(uuid())
  projectId       String
  wbsId           String
  costType        CostType        @default(material)
  amount          Decimal         @db.Decimal(18, 2)
  quantity        Decimal         @default(1) @db.Decimal(18, 2)
  unitPrice       Decimal         @default(0) @db.Decimal(18, 2)
  supplier        String?
  note            String?
  date            DateTime        @default(now())
  status          PaymentStatus   @default(unpaid)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  approvalStatus  ApprovalStatus  @default(DRAFT)
  branchId        String?
  companyId       String?
  createdById     String?
  deletedAt       DateTime?
  deletedById     String?
  netAmount       Decimal         @default(0) @db.Decimal(18, 2)
  purchaseOrderId String?
  requestId       String?         @unique
  retentionAmount Decimal         @default(0) @db.Decimal(18, 2)
  retentionRate   Decimal         @default(0) @db.Decimal(5, 2)
  vatAmount       Decimal         @default(0) @db.Decimal(18, 2)
  vatRate         Decimal         @default(10) @db.Decimal(5, 2)
  version         Int             @default(1)
  workflowStatus  String          @default("DRAFT")
  branch          Branch?         @relation(fields: [branchId], references: [id])
  company         Company?        @relation(fields: [companyId], references: [id])
  createdBy       User?           @relation("CostCreatedBy", fields: [createdById], references: [id])
  deletedBy       User?           @relation("CostDeletedBy", fields: [deletedById], references: [id])
  purchaseOrder   PurchaseOrder?  @relation(fields: [purchaseOrderId], references: [id])
  wbs             WBSItem         @relation(fields: [wbsId], references: [id])
  vendorPayments  VendorPayment[]

  @@index([date])
  @@index([projectId, deletedAt, date])
  @@index([wbsId, deletedAt])
}

model BudgetRecord {
  id              String    @id @default(uuid())
  projectId       String
  wbsId           String
  costType        CostType  @default(material)
  estimatedAmount Decimal   @db.Decimal(18, 2)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  createdById     String?
  deletedAt       DateTime?
  createdBy       User?     @relation("BudgetCreatedBy", fields: [createdById], references: [id])
  wbs             WBSItem   @relation(fields: [wbsId], references: [id])

  @@index([projectId, deletedAt])
  @@index([wbsId, deletedAt])
}

model Revenue {
  id          String        @id @default(uuid())
  projectId   String
  wbsId       String
  invoiceId   String?
  amount      Decimal       @db.Decimal(18, 2)
  date        DateTime      @default(now())
  status      PaymentStatus @default(unpaid)
  description String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  createdById String?
  deletedAt   DateTime?
  createdBy   User?         @relation("RevenueCreatedBy", fields: [createdById], references: [id])
  invoice     Invoice?      @relation(fields: [invoiceId], references: [id])
  wbs         WBSItem       @relation(fields: [wbsId], references: [id])

  @@index([projectId, deletedAt, date])
  @@index([wbsId, deletedAt])
}

model Invoice {
  id                 String              @id @default(uuid())
  projectId          String
  wbsId              String
  amount             Decimal             @db.Decimal(18, 2)
  issuedDate         DateTime            @default(now())
  paidAmount         Decimal             @default(0) @db.Decimal(18, 2)
  remainingAmount    Decimal             @db.Decimal(18, 2)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  approvalStatus     ApprovalStatus      @default(DRAFT)
  branchId           String?
  certifiedProgress  Decimal             @default(0) @db.Decimal(18, 2)
  companyId          String?
  contractId         String?
  createdById        String?
  deletedAt          DateTime?
  deletedById        String?
  dueDate            DateTime?
  invoiceNumber      String?
  netAmount          Decimal             @default(0) @db.Decimal(18, 2)
  note               String?
  requestId          String?             @unique
  retentionAmount    Decimal             @default(0) @db.Decimal(18, 2)
  retentionRate      Decimal             @default(0) @db.Decimal(5, 2)
  vatAmount          Decimal             @default(0) @db.Decimal(18, 2)
  vatRate            Decimal             @default(10) @db.Decimal(5, 2)
  version            Int                 @default(1)
  status             InvoiceStatus       @default(DRAFT)
  advanceSettlements AdvanceSettlement[]
  branch             Branch?             @relation(fields: [branchId], references: [id])
  company            Company?            @relation(fields: [companyId], references: [id])
  contract           Contract?           @relation(fields: [contractId], references: [id])
  createdBy          User?               @relation("InvoiceCreatedBy", fields: [createdById], references: [id])
  deletedBy          User?               @relation("InvoiceDeletedBy", fields: [deletedById], references: [id])
  wbs                WBSItem             @relation(fields: [wbsId], references: [id])
  payments           Payment[]
  allocations        PaymentAllocation[]
  revenues           Revenue[]

  @@index([projectId, deletedAt, issuedDate])
  @@index([wbsId, deletedAt])
}

model Payment {
  id             String              @id @default(uuid())
  invoiceId      String?
  projectId      String
  amount         Decimal             @db.Decimal(18, 2)
  date           DateTime            @default(now())
  description    String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  approvalStatus ApprovalStatus      @default(DRAFT)
  deletedAt      DateTime?
  deletedById    String?
  requestId      String?             @unique
  version        Int                 @default(1)
  contractId     String?
  contract       Contract?           @relation(fields: [contractId], references: [id])
  deletedBy      User?               @relation("PaymentDeletedBy", fields: [deletedById], references: [id])
  invoice        Invoice?            @relation(fields: [invoiceId], references: [id])
  allocations    PaymentAllocation[]

  @@index([invoiceId, deletedAt])
  @@index([projectId, deletedAt, date])
}

model LedgerAccount {
  id                  String             @id @default(uuid())
  code                String             @unique
  name                String
  type                AccountType
  description         String?
  isActive            Boolean            @default(true)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  deletedAt           DateTime?
  parentId            String?
  creditCashDocuments CashBankDocument[] @relation("CreditAccount")
  debitCashDocuments  CashBankDocument[] @relation("DebitAccount")
  parent              LedgerAccount?     @relation("AccountHierarchy", fields: [parentId], references: [id])
  children            LedgerAccount[]    @relation("AccountHierarchy")
  lines               TransactionLine[]

  @@index([code])
  @@index([type])
  @@index([parentId])
}

model JournalEntry {
  id           String            @id @default(uuid())
  projectId    String?
  date         DateTime          @default(now())
  description  String
  reference    String?
  sourceType   String?
  sourceId     String?
  isPosted     Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  deletedAt    DateTime?
  isReversed   Boolean           @default(false)
  reversalRef  String?
  reversedById String?
  isClosing    Boolean           @default(false)
  status       String            @default("DA_CAT")
  project      Project?          @relation(fields: [projectId], references: [id])
  lines        TransactionLine[]

  @@unique([sourceType, sourceId, deletedAt])
  @@index([date])
  @@index([projectId, deletedAt, date])
  @@index([isReversed, projectId])
}

model TransactionLine {
  id             String          @id @default(uuid())
  journalEntryId String
  accountId      String
  amount         Decimal         @db.Decimal(18, 2)
  type           TransactionType
  description    String?
  deletedAt      DateTime?
  account        LedgerAccount   @relation(fields: [accountId], references: [id])
  journalEntry   JournalEntry    @relation(fields: [journalEntryId], references: [id])

  @@index([journalEntryId])
  @@index([accountId])
}

model PurchaseRequest {
  id             String            @id @default(uuid())
  projectId      String
  wbsId          String?
  title          String
  description    String?
  requestedBy    String?
  status         ProcurementStatus @default(DRAFT)
  totalAmount    Decimal           @default(0) @db.Decimal(18, 2)
  requestDate    DateTime          @default(now())
  neededBy       DateTime?
  createdById    String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  deletedAt      DateTime?
  purchaseOrders PurchaseOrder[]
  createdBy      User?             @relation("PRCreatedBy", fields: [createdById], references: [id])
  quotations     Quotation[]

  @@index([projectId])
  @@index([status])
}

model PurchaseOrder {
  id                String              @id @default(uuid())
  projectId         String
  purchaseRequestId String?
  poNumber          String?             @unique
  vendor            String
  description       String?
  status            ProcurementStatus   @default(DRAFT)
  totalAmount       Decimal             @db.Decimal(18, 2)
  orderedDate       DateTime            @default(now())
  expectedDelivery  DateTime?
  createdById       String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  deletedAt         DateTime?
  costRecords       CostRecord[]
  goodsReceipts     GoodsReceipt[]
  createdBy         User?               @relation("POCreatedBy", fields: [createdById], references: [id])
  project           Project             @relation(fields: [projectId], references: [id])
  purchaseRequest   PurchaseRequest?    @relation(fields: [purchaseRequestId], references: [id])
  items             PurchaseOrderItem[]

  @@index([projectId])
  @@index([status])
}

model PurchaseOrderItem {
  id              String        @id @default(uuid())
  purchaseOrderId String
  wbsId           String?
  description     String
  quantity        Decimal       @db.Decimal(18, 4)
  unitPrice       Decimal       @db.Decimal(18, 2)
  amount          Decimal       @db.Decimal(18, 2)
  costType        CostType      @default(material)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  wbs             WBSItem?      @relation(fields: [wbsId], references: [id])

  @@index([purchaseOrderId])
}

model GoodsReceipt {
  id              String        @id @default(uuid())
  purchaseOrderId String
  projectId       String
  receivedDate    DateTime      @default(now())
  notes           String?
  receivedById    String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])

  @@index([purchaseOrderId])
  @@index([projectId])
}

model Contract {
  id                String              @id @default(uuid())
  projectId         String
  contractNumber    String?             @unique
  title             String
  description       String?
  contractorName    String?
  originalValue     Decimal             @db.Decimal(18, 2)
  currentValue      Decimal             @db.Decimal(18, 2)
  status            ContractStatus      @default(DRAFT)
  signedDate        DateTime?
  startDate         DateTime?
  endDate           DateTime?
  createdById       String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  deletedAt         DateTime?
  contractCode      String?
  supplierId        String?
  acceptances       Acceptance[]
  advanceRequests   AdvanceRequest[]
  CashBankDocument  CashBankDocument[]
  createdBy         User?               @relation("ContractCreatedBy", fields: [createdById], references: [id])
  project           Project             @relation(fields: [projectId], references: [id])
  supplier          Supplier?           @relation(fields: [supplierId], references: [id])
  changes           ContractChange[]
  documentChecklist DocumentChecklist[]
  InventoryDocument InventoryDocument[]
  invoices          Invoice[]
  payments          Payment[]
  PaymentAllocation PaymentAllocation[]
  paymentPlans      PaymentPlan[]
  TaxInvoice        TaxInvoice[]

  @@unique([projectId, supplierId, contractCode])
  @@index([projectId])
  @@index([status])
}

model ContractChange {
  id           String    @id @default(uuid())
  contractId   String
  voNumber     String?
  title        String
  description  String?
  changeAmount Decimal   @db.Decimal(18, 2)
  approvedDate DateTime?
  status       String    @default("PENDING")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  contract     Contract  @relation(fields: [contractId], references: [id])

  @@index([contractId])
}

model AuditLog {
  id            String   @id @default(uuid())
  userId        String?
  action        String
  entity        String
  entityId      String
  oldData       Json?
  newData       Json?
  timestamp     DateTime @default(now())
  ipAddress     String?
  userAgent     String?
  correlationId String?
  reason        String?
  requestId     String?
  severity      String   @default("INFO")
  user          User?    @relation(fields: [userId], references: [id])

  @@index([entity, entityId])
  @@index([timestamp])
  @@index([userId])
  @@index([correlationId])
  @@index([requestId])
}

model ActivityFeed {
  id         String   @id
  projectId  String
  userId     String
  action     String
  entityType String
  entityId   String
  message    String
  metadata   Json?
  createdAt  DateTime @default(now())
  Project    Project  @relation(fields: [projectId], references: [id])
  User       User     @relation(fields: [userId], references: [id])

  @@index([createdAt])
  @@index([projectId])
}

model ApprovalRequest {
  id           String         @id
  projectId    String
  requesterId  String
  entityType   String
  entityId     String?
  requestData  Json?
  status       ApprovalStatus @default(PENDING)
  reason       String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime
  Project      Project        @relation(fields: [projectId], references: [id])
  User         User           @relation(fields: [requesterId], references: [id])
  ApprovalStep ApprovalStep[]

  @@index([projectId])
  @@index([requesterId])
  @@index([status])
}

model ApprovalStep {
  id                String          @id
  approvalRequestId String
  approverId        String
  status            ApprovalStatus  @default(PENDING)
  comment           String?
  stepOrder         Int             @default(1)
  processedAt       DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime
  ApprovalRequest   ApprovalRequest @relation(fields: [approvalRequestId], references: [id])
  User              User            @relation(fields: [approverId], references: [id])

  @@index([approvalRequestId])
  @@index([approverId])
}

model AuthorityMatrix {
  id          String   @id
  role        UserRole
  maxAmount   Decimal  @db.Decimal(18, 2)
  entityType  String
  projectType String?
  priority    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime
}

model BOQItem {
  id            String          @id @default(uuid())
  projectId     String
  wbsId         String
  description   String
  unit          String
  quantity      Decimal         @db.Decimal(18, 3)
  unitRate      Decimal         @db.Decimal(18, 2)
  totalAmount   Decimal         @db.Decimal(18, 2)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  deletedAt     DateTime?
  status        String          @default("ACTIVE")
  version       Int             @default(1)
  Project       Project         @relation(fields: [projectId], references: [id])
  WBSItem       WBSItem         @relation(fields: [wbsId], references: [id])
  ProgressEntry ProgressEntry[]

  @@index([projectId])
  @@index([wbsId])
}

model BudgetVersion {
  id          String   @id @default(uuid())
  projectId   String
  version     Int
  description String?
  status      String   @default("DRAFT")
  snapshot    Json
  createdAt   DateTime @default(now())
  createdById String?
  project     Project  @relation(fields: [projectId], references: [id])

  @@index([projectId])
}

model Comment {
  id         String    @id
  userId     String
  entityType String
  entityId   String
  content    String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime
  deletedAt  DateTime?
  User       User      @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
}

model DelegationPolicy {
  id        String   @id
  name      String
  rules     Json
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model DelegationWindow {
  id                                     String   @id
  ownerId                                String
  delegateId                             String
  startDate                              DateTime
  endDate                                DateTime
  reason                                 String?
  isActive                               Boolean  @default(true)
  createdAt                              DateTime @default(now())
  updatedAt                              DateTime
  User_DelegationWindow_delegateIdToUser User     @relation("DelegationWindow_delegateIdToUser", fields: [delegateId], references: [id])
  User_DelegationWindow_ownerIdToUser    User     @relation("DelegationWindow_ownerIdToUser", fields: [ownerId], references: [id])
}

model Document {
  id           String    @id
  projectId    String
  name         String
  url          String
  type         String
  version      Int       @default(1)
  size         Int?
  sourceType   String?
  sourceId     String?
  uploadedById String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime
  deletedAt    DateTime?
  Project      Project   @relation(fields: [projectId], references: [id])
  User         User      @relation(fields: [uploadedById], references: [id])

  @@index([projectId])
  @@index([sourceType, sourceId])
}

model FiscalPeriod {
  id             String    @id @default(uuid())
  isLocked       Boolean   @default(false)
  lockedAt       DateTime?
  lockedById     String?
  closingBalance Decimal?  @db.Decimal(18, 2)
  reconciledAt   DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  companyId      String?
  endDate        DateTime?
  name           String?
  startDate      DateTime?
  month          String    @unique
  Company        Company?  @relation(fields: [companyId], references: [id])
  User           User?     @relation(fields: [lockedById], references: [id])

  @@index([month])
}

model Job {
  id          String    @id @default(uuid())
  type        String
  status      String    @default("PENDING")
  payload     Json?
  result      Json?
  error       String?
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  priority    Int       @default(0)
  runAt       DateTime  @default(now())
  processedAt DateTime?
  finishedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, runAt])
  @@index([type])
}

model InventoryTransaction {
  id          String                   @id
  projectId   String
  materialId  String
  type        InventoryTransactionType
  quantity    Decimal                  @db.Decimal(18, 3)
  unitPrice   Decimal?                 @db.Decimal(18, 2)
  referenceId String?
