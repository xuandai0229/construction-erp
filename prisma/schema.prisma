  @@index([userId, isRead])
  @@index([createdAt])
}

model DomainEvent {
  id          String    @id @default(uuid())
  type        String
  payload     Json
  metadata    Json?
  status      String    @default("PENDING")
  error       String?
  projectId   String?
  timestamp   DateTime  @default(now())
  processedAt DateTime?

  @@index([status, timestamp])
  @@index([projectId])
}

model FinancialSnapshot {
  id           String   @id @default(uuid())
  projectId    String?
  companyId    String?  // Tenant isolation
  periodId     String?  // FiscalPeriod relation
  snapshotType String   @default("MONTHLY") // MONTHLY, QUARTERLY, ANNUAL, PROJECT_END
  version      String
  data         Json
  isLocked     Boolean  @default(true) // Immutable by default
  createdBy    String?
  reason       String?
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())

  @@index([projectId, snapshotType])
  @@index([companyId, periodId])
}

