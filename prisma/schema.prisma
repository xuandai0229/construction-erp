generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum UserRole {
  ADMIN
  MANAGER
  ACCOUNTANT
  VIEWER
}

enum ProjectStatus {
  PLANNED
  IN_PROGRESS
  ACTIVE
  COMPLETED
  CLOSED
  CANCELLED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum CostType {
  material
  labor
  machine
  subcontract
  overhead
  other
}

enum PaymentStatus {
  paid
  unpaid
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIAL
  PAID
  OVERDUE
}

// ─────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  role      UserRole @default(VIEWER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  projectsOwned    Project[]  @relation("ProjectOwner")
  tasksAssigned    Task[]
  costsCreated     CostRecord[]   @relation("CostCreatedBy")
  budgetsCreated   BudgetRecord[] @relation("BudgetCreatedBy")
  revenuesCreated  Revenue[]      @relation("RevenueCreatedBy")
  invoicesCreated  Invoice[]      @relation("InvoiceCreatedBy")

  @@index([createdAt])
  @@index([role])
}

// ─────────────────────────────────────────────
// CATEGORY
// ─────────────────────────────────────────────

model Category {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  tasks Task[]

  @@index([createdAt])
}

// ─────────────────────────────────────────────
// PROJECT
// ─────────────────────────────────────────────

model Project {
  id            String        @id @default(uuid())
  name          String
  description   String?
  status        ProjectStatus @default(PLANNED)
  ownerId       String?

  // Financial fields
  contractValue Float         @default(0)
  totalBudget   Float         @default(0)

  // Schedule
  startDate     DateTime?
  endDate       DateTime?

  // Audit
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?

  owner     User?    @relation("ProjectOwner", fields: [ownerId], references: [id])
  tasks     Task[]
  wbsItems  WBSItem[]

  @@index([status])
  @@index([createdAt])
  @@index([ownerId])
}

// ─────────────────────────────────────────────
// TASK
// ─────────────────────────────────────────────

model Task {
  id          String     @id @default(uuid())
  title       String
  description String?
  status      TaskStatus @default(TODO)
  projectId   String
  categoryId  String?
  assigneeId  String?
  dueDate     DateTime?
  priority    Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?

  project  Project   @relation(fields: [projectId], references: [id])
  category Category? @relation(fields: [categoryId], references: [id])
  assignee User?     @relation(fields: [assigneeId], references: [id])

  @@index([projectId])
  @@index([status])
  @@index([assigneeId])
  @@index([categoryId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────
// WBS
// ─────────────────────────────────────────────

model WBSItem {
  id        String  @id @default(uuid())
  projectId String
  name      String
  code      String?
  parentId  String?
  level     Int     @default(0)
  sortOrder Int     @default(0)

  budgetAmount Float @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project  Project   @relation(fields: [projectId], references: [id])
  parent   WBSItem?  @relation("WBSChildren", fields: [parentId], references: [id])
  children WBSItem[] @relation("WBSChildren")

  costs    CostRecord[]
  budgets  BudgetRecord[]
  revenues Revenue[]
  invoices Invoice[]

  @@index([projectId])
  @@index([parentId])
}

// ─────────────────────────────────────────────
// COST RECORD
// ─────────────────────────────────────────────

model CostRecord {
  id          String        @id @default(uuid())
  projectId   String
  wbsId       String
  costType    CostType      @default(material)
  amount      Float
  quantity    Float         @default(1)
  unitPrice   Float         @default(0)
  supplier    String?
  note        String?
  date        DateTime      @default(now())
  status      PaymentStatus @default(unpaid)

  createdById String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  wbs       WBSItem @relation(fields: [wbsId], references: [id])
  createdBy User?   @relation("CostCreatedBy", fields: [createdById], references: [id])

  @@index([projectId])
  @@index([wbsId])
  @@index([date])
}

// ─────────────────────────────────────────────
// BUDGET RECORD
// ─────────────────────────────────────────────

model BudgetRecord {
  id              String   @id @default(uuid())
  projectId       String
  wbsId           String
  costType        CostType @default(material)
  estimatedAmount Float

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  wbs       WBSItem @relation(fields: [wbsId], references: [id])
  createdBy User?   @relation("BudgetCreatedBy", fields: [createdById], references: [id])

  @@index([projectId])
  @@index([wbsId])
}

// ─────────────────────────────────────────────
// REVENUE
// ─────────────────────────────────────────────

model Revenue {
  id          String        @id @default(uuid())
  projectId   String
  wbsId       String
  invoiceId   String?
  amount      Float
  date        DateTime      @default(now())
  status      PaymentStatus @default(unpaid)
  description String?

  createdById String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  wbs       WBSItem  @relation(fields: [wbsId], references: [id])
  invoice   Invoice? @relation(fields: [invoiceId], references: [id])
  createdBy User?    @relation("RevenueCreatedBy", fields: [createdById], references: [id])

  @@index([projectId])
  @@index([wbsId])
}

// ─────────────────────────────────────────────
// INVOICE
// ─────────────────────────────────────────────

model Invoice {
  id              String        @id @default(uuid())
  projectId       String
  wbsId           String
  invoiceNumber   String?
  amount          Float
  issuedDate      DateTime      @default(now())
  dueDate         DateTime?
  paidAmount      Float         @default(0)
  remainingAmount Float
  status          InvoiceStatus @default(DRAFT)
  note            String?

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  wbs       WBSItem   @relation(fields: [wbsId], references: [id])
  payments  Payment[]
  revenues  Revenue[]
  createdBy User?     @relation("InvoiceCreatedBy", fields: [createdById], references: [id])

  @@index([projectId])
  @@index([wbsId])
}

// ─────────────────────────────────────────────
// PAYMENT
// ─────────────────────────────────────────────

model Payment {
  id          String   @id @default(uuid())
  invoiceId   String
  projectId   String
  amount      Float
  date        DateTime @default(now())
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
  @@index([projectId])
}